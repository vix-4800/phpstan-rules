includes:
  - rules.neon

parametersSchema:
  yiiPolicy: structure([
    allowedSaveFalseNamespaces: listOf(string()),
    rules: structure([
      activeDataProviderWithoutPagination: bool(),
      all: bool(),
      componentInitParentCall: bool(),
      controllerBeforeActionParentResultIgnored: bool(),
      csrfDisabledWithoutCompensatingControl: bool(),
      deleteAllOrUpdateAllWithoutWhere: bool(),
      fileValidatorTooLoose: bool(),
      imageValidatorTooLoose: bool(),
      lifecycleParentCall: bool(),
      lifecycleSelfSave: bool(),
      massSelectionWithoutLimit: bool(),
      missingAccessRule: bool(),
      missingAjaxFilterRule: bool(),
      missingVerbFilterRule: bool(),
      mixedResponseTypesInAction: bool(),
      mutatingActionAllowsGet: bool(),
      nPlusOneRelationInLoop: bool(),
      nativeHeaderInController: bool(),
      publicAllowWithoutConstraint: bool(),
      queryOneWithoutLimit: bool(),
      queryPerformanceSmell: bool(),
      rawSqlConditionWithVariable: bool(),
      redirectReferrerWithoutFallback: bool(),
      saveFalseWithoutReason: bool(),
      scenarioAssignedAfterLoad: bool(),
      transactionWithoutRollbackHandling: bool(),
      unboundedQueryResult: bool(),
      unknownActionInBehavior: bool(),
    ]),
  ])

parameters:
  yiiPolicy:
    allowedSaveFalseNamespaces: []
    rules:
      all: false
      componentInitParentCall: false
      csrfDisabledWithoutCompensatingControl: false
      deleteAllOrUpdateAllWithoutWhere: false
      fileValidatorTooLoose: false
      imageValidatorTooLoose: false
      lifecycleParentCall: false
      lifecycleSelfSave: false
      massSelectionWithoutLimit: false
      missingAccessRule: false
      missingAjaxFilterRule: false
      missingVerbFilterRule: false
      mixedResponseTypesInAction: false
      mutatingActionAllowsGet: false
      nativeHeaderInController: false
      publicAllowWithoutConstraint: false
      queryOneWithoutLimit: false
      queryPerformanceSmell: false
      rawSqlConditionWithVariable: false
      redirectReferrerWithoutFallback: false
      saveFalseWithoutReason: false
      transactionWithoutRollbackHandling: false
      unboundedQueryResult: false
      unknownActionInBehavior: false
