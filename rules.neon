services:
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\SaveFalseWithoutReasonRule
    arguments:
      allowedNamespaces: %yiiPolicy.allowedSaveFalseNamespaces%
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\LifecycleParentCallRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\ComponentInitParentCallRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\MissingAccessRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\MissingVerbFilterRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\MissingAjaxFilterRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\UnknownActionInBehaviorRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\MassSelectionWithoutLimitRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\PublicAllowWithoutConstraintRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\MutatingActionAllowsGetRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\CsrfDisabledWithoutCompensatingControlRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\RawSqlConditionWithVariableRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\QueryOneWithoutLimitRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\RedirectReferrerWithoutFallbackRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\NativeHeaderInControllerRule
    tags:
      - phpstan.rules.rule
  -
    class: Vix\PhpstanYiiPolicyRules\Rules\UnboundedQueryResultRule
    tags:
      - phpstan.rules.rule
